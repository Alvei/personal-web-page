---
import type { Post } from "../lib/posts";

type Props = {
  post: Post;
  compact?: boolean;
};

const { post, compact = false } = Astro.props;

const published = post.publishedAt.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
---

<article class:list={["post-card", compact && "post-card-compact"]}>
  <div class="post-card-meta">
    <p class="eyebrow">Blog</p>
    <p class="post-card-date">{published}</p>
  </div>
  <h2>
    <a href={`/posts/${post.slug}/`}>{post.title}</a>
  </h2>
  <p class="summary">{post.summary}</p>
  <ul class="tag-list" aria-label="Tags">
    {post.tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>
