---
type Props = {
  currentPath?: string;
};

const { currentPath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/posts", label: "Posts" }
];
---

<header class="site-header">
  <a class="brand" href="/">A Quiet Corner</a>
  <nav aria-label="Primary">
    <ul>
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath === link.href ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
