---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getLatestPosts } from "../lib/posts";
import { topics } from "../lib/topics";

const posts = await getLatestPosts(3);
---

<BaseLayout
  title="Hugo's musing"
  description="A personal blog for essays, notes, and questions worth returning to."
>
  <section class="hero">
    <p class="eyebrow">Notes and essays</p>
    <h1>Thoughts on work, learning, and ideas worth revisiting.</h1>
    <p class="lede">
      A place to think in public about AI, learning, and the systems that shape
      how people and organizations grow.
    </p>
    <div class="hero-actions">
      <a class="button-primary" href="/posts">Read the archive</a>
    </div>
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Latest writing</p>
      <h2>Recent posts</h2>
    </div>
    <a class="section-link" href="/posts">View all posts</a>
  </section>

  <section class="post-grid" aria-label="Recent posts">
    {posts.map((post) => <PostCard post={post} />)}
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Explore further</p>
      <h2>Topic pages</h2>
    </div>
    <a class="section-link" href="/topics">Browse all topics</a>
  </section>

  <section class="topic-grid" aria-label="Topic pages">
    {topics.map((topic) => (
      <article class="topic-card">
        <p class="eyebrow">Topic</p>
        <h2>
          <a href={`/topics/${topic.slug}/`}>{topic.title}</a>
        </h2>
        <p class="summary">{topic.description}</p>
      </article>
    ))}
  </section>
</BaseLayout>
