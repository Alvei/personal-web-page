---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
  slug: string;
};

const { title, description, publishedAt, updatedAt, tags, slug } = Astro.props;

const published = publishedAt.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const updated = updatedAt?.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
---

<BaseLayout
  title={`${title} | A Quiet Corner`}
  description={description}
  canonicalPath={`/posts/${slug}/`}
>
  <article class="post-shell">
    <header class="post-header">
      <p class="eyebrow">{published}</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <div class="post-meta">
        <ul class="tag-list" aria-label="Tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
        {updated && <p class="updated">Updated {updated}</p>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
