---
import BaseLayout from "./BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getRelatedPosts } from "../lib/posts";

type Props = {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
  slug: string;
};

const { title, description, publishedAt, updatedAt, tags, slug } = Astro.props;
const relatedPosts = await getRelatedPosts(slug, tags, 3);
const siteUrl = new URL(Astro.site ?? "https://example.com");
const canonicalUrl = new URL(`/posts/${slug}/`, siteUrl).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  ...(updatedAt ? { dateModified: updatedAt.toISOString() } : {}),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: "Hugo Sarrazin"
  },
  publisher: {
    "@type": "Person",
    name: "Hugo Sarrazin"
  },
  keywords: tags.join(", ")
};

const published = publishedAt.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});

const updated = updatedAt?.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
---

<BaseLayout
  title={`${title} | Hugo's musing`}
  description={description}
  canonicalPath={`/posts/${slug}/`}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <article class="post-shell">
    <header class="post-header">
      <p class="eyebrow">{published}</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <div class="post-meta">
        <ul class="tag-list" aria-label="Tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
        {updated && <p class="updated">Updated {updated}</p>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <aside class="author-box" aria-label="About the author">
      <p class="eyebrow">About the author</p>
      <h2>Hugo Sarrazin</h2>
      <p>
        I write about AI, learning, and how work changes when intelligence
        becomes more abundant. This blog is a place to think in public about
        capability building, better systems, and ideas worth revisiting.
      </p>
      <a class="topic-link" href="/about/">Read more about Hugo</a>
    </aside>
  </article>
  {relatedPosts.length > 0 && (
    <section class="related-posts">
      <div class="related-posts-heading">
        <p class="eyebrow">Continue Reading</p>
        <h2>Related posts</h2>
      </div>
      <div class="post-grid" aria-label="Related posts">
        {relatedPosts.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  )}
</BaseLayout>
